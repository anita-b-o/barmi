DB_NAME=barmi
DB_USER=barmi
DB_PASSWORD=change-me-strong-db-pass

# Replace these placeholders before running staging or prod validation.
JWT_SECRET=example-jwt-secret-change-this-to-a-strong-random-value-32-bytes-min
MP_WEBHOOK_SECRET=example-mp-webhook-secret-change-this-to-a-strong-random-value-32-bytes-min
MP_ACCESS_TOKEN=
APP_VERSION=staging-local
APP_COMMIT_SHA=replace-with-short-sha
APP_BUILD_TIMESTAMP=2026-01-01T00:00:00.000Z

STORE_BASE_DOMAIN=staging.127.0.0.1.sslip.io
DEFAULT_CURRENCY=ARS
STORE_PUBLIC_SCHEME=https
NOTIFICATION_EMAIL_MODE=logging
NOTIFICATION_EMAIL_FROM=no-reply@staging.127.0.0.1.sslip.io
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
OBSERVABILITY_OUTBOX_BACKLOG_THRESHOLD=1000
APP_OBSERVABILITY_SMOKE_ENABLED=true
ALLOWED_ORIGINS=https://staging.127.0.0.1.sslip.io:8443,https://demo-store.staging.127.0.0.1.sslip.io:8443,https://casa-roja.staging.127.0.0.1.sslip.io:8443,https://mercado-centro.staging.127.0.0.1.sslip.io:8443,https://admin.staging.127.0.0.1.sslip.io:8443
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_DOMAIN=staging.127.0.0.1.sslip.io
REFRESH_COOKIE_SAMESITE=Lax
MP_PUBLIC_BASE_URL=

# Frontend public envs (define them in frontend/.env.local, your preview platform,
# or your deploy provider env settings; never store private secrets in Vite envs)
VITE_API_BASE_URL=
VITE_PUBLIC_STORE_HOST=demo-store.staging.127.0.0.1.sslip.io
VITE_PUBLIC_ECOSYSTEM_SLUG=demo-ecosystem
VITE_APP_ENV=staging
VITE_APP_VERSION=staging-local
VITE_APP_COMMIT_SHA=replace-with-short-sha
VITE_APP_BUILD_TIMESTAMP=2026-01-01T00:00:00.000Z
VITE_APP_RELEASE_ID=staging-local+replace-with-short-sha
VITE_SENTRY_DSN=
VITE_OBSERVABILITY_SMOKE_ENABLED=true
VITE_OBSERVABILITY_INGEST_URL=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTO_UPLOAD=false
SENTRY_UPLOAD_REQUIRED=false
STAGING_HTTP_PORT=8088
STAGING_HTTPS_PORT=8443
STAGING_DB_PORT=5435
