FROM node:20-bookworm-slim AS build
WORKDIR /app
ARG VITE_API_BASE_URL=
ARG VITE_PUBLIC_STORE_HOST=demo-store.example.com
ARG VITE_PUBLIC_ECOSYSTEM_SLUG=demo-ecosystem
ARG VITE_APP_ENV=staging
ARG VITE_APP_VERSION=staging
ARG VITE_APP_COMMIT_SHA=unknown
ARG VITE_APP_BUILD_TIMESTAMP=unknown
ARG VITE_APP_RELEASE_ID=staging+unknown
ARG VITE_SENTRY_DSN=
ARG VITE_OBSERVABILITY_SMOKE_ENABLED=false
ARG VITE_SENTRY_SMOKE_ENABLED=false
ARG VITE_OBSERVABILITY_INGEST_URL=
ARG SENTRY_AUTH_TOKEN=
ARG SENTRY_ORG=
ARG SENTRY_PROJECT=
ARG SENTRY_AUTO_UPLOAD=false
ARG SENTRY_UPLOAD_REQUIRED=false
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_PUBLIC_STORE_HOST=$VITE_PUBLIC_STORE_HOST
ENV VITE_PUBLIC_ECOSYSTEM_SLUG=$VITE_PUBLIC_ECOSYSTEM_SLUG
ENV VITE_APP_ENV=$VITE_APP_ENV
ENV VITE_APP_VERSION=$VITE_APP_VERSION
ENV VITE_APP_COMMIT_SHA=$VITE_APP_COMMIT_SHA
ENV VITE_APP_BUILD_TIMESTAMP=$VITE_APP_BUILD_TIMESTAMP
ENV VITE_APP_RELEASE_ID=$VITE_APP_RELEASE_ID
ENV VITE_SENTRY_DSN=$VITE_SENTRY_DSN
ENV VITE_OBSERVABILITY_SMOKE_ENABLED=$VITE_OBSERVABILITY_SMOKE_ENABLED
ENV VITE_SENTRY_SMOKE_ENABLED=$VITE_SENTRY_SMOKE_ENABLED
ENV VITE_OBSERVABILITY_INGEST_URL=$VITE_OBSERVABILITY_INGEST_URL
ENV SENTRY_AUTH_TOKEN=$SENTRY_AUTH_TOKEN
ENV SENTRY_ORG=$SENTRY_ORG
ENV SENTRY_PROJECT=$SENTRY_PROJECT
ENV SENTRY_AUTO_UPLOAD=$SENTRY_AUTO_UPLOAD
ENV SENTRY_UPLOAD_REQUIRED=$SENTRY_UPLOAD_REQUIRED
COPY package.json package-lock.json* ./
RUN npm ci --no-audit --no-fund
COPY . .
RUN npm run build

FROM nginx:1.27
ARG VITE_APP_VERSION=unknown
ARG VITE_APP_COMMIT_SHA=unknown
ARG VITE_APP_BUILD_TIMESTAMP=unknown
ARG VITE_APP_RELEASE_ID=unknown
LABEL org.opencontainers.image.title="barmi-web"
LABEL org.opencontainers.image.version="$VITE_APP_VERSION"
LABEL org.opencontainers.image.revision="$VITE_APP_COMMIT_SHA"
LABEL org.opencontainers.image.created="$VITE_APP_BUILD_TIMESTAMP"
LABEL io.barmi.release_id="$VITE_APP_RELEASE_ID"
COPY nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
