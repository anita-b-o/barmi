{
  "name": "barmi-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "npm run check:architecture && npm run check:design-system",
    "lint:imports": "node ./scripts/check-architecture.mjs",
    "preview": "vite preview",
    "check:architecture": "node ./scripts/check-architecture.mjs",
    "check:design-system": "node ./scripts/check-design-system.mjs",
    "audit:design-system": "node ./scripts/audit-design-system.mjs",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest",
    "test:baseline": "CI=1 ./node_modules/.bin/vitest run src/__tests__/routing.test.tsx src/__tests__/admin-store-products.test.tsx src/__tests__/admin-ecosystem-products.test.tsx src/__tests__/admin-fulfillment.test.tsx src/__tests__/admin-ecosystem-fulfillment.test.tsx src/__tests__/ui-feedback.test.tsx --api.port=0",
    "validate:baseline": "npm run check:architecture && npm run test:baseline",
    "validate:full": "npm run check:architecture && npm run build && npm run test:baseline",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/material": "^5.16.7",
    "@tanstack/react-query": "^5.59.16",
    "axios": "^1.7.7",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.26.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@storybook/addon-a11y": "^8.6.12",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/react-vite": "^8.6.12",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^28.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^1.6.0"
  }
}
